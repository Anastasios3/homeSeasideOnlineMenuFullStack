# Backend API URL (no trailing slash). Used by every API call in the app
# and consumed by getApiUrl() in src/config/api.ts.
VITE_API_URL=http://localhost:3000

# Canonical site origin for SEO (canonical tags, sitemap.xml, og.jpg).
# No trailing slash. Read by src/seo.ts.
VITE_SITE_URL=https://home-seaside.gr
