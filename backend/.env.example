# ─── Database (REQUIRED) ─────────────────────────────────────────────
# MongoDB Atlas SRV connection string. Include the database name in the
# path (e.g. .../homeSeaside?retryWrites=true&w=majority).
# Read by config/mongoid.yml in BOTH development and production.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/homeSeaside?retryWrites=true&w=majority

# ─── Auth (REQUIRED in production) ───────────────────────────────────
# Stable secret for HS256 JWTs. If unset, falls back to
# Rails.application.secret_key_base — but if secret_key_base rotates
# (credentials reset), all live admin sessions invalidate. Set this
# explicitly in prod so it's controllable. Generate with:
#   openssl rand -hex 64
JWT_SECRET=replace-with-64-random-hex-chars

# Admin password used ONLY by `bin/rails db:seed` to create the single
# admin user. Changing it later requires re-seeding or updating the
# AdminUser document directly via console. Use a strong unique value.
ADMIN_PASSWORD=change-me-strong-password

# Rails credentials key (REQUIRED in production; never commit).
# Already wired in .kamal/secrets via `cat config/master.key`.
RAILS_MASTER_KEY=

# ─── HTTP / CORS (REQUIRED in production) ────────────────────────────
# Comma-separated allowlist for browser origins hitting the API.
# Include both apex and www if you serve both.
CORS_ORIGINS=https://home-seaside.gr,https://www.home-seaside.gr

# Comma-separated Host header allowlist (DNS-rebinding protection).
# Production will reject requests without a matching Host header.
# The bare apex + the API subdomain are typical.
ALLOWED_HOSTS=api.home-seaside.gr

# Host the mailer uses to generate absolute URLs in templates.
# No scheme, just the bare domain.
APP_HOST=home-seaside.gr

# ─── S3 uploads (OPTIONAL — leave blank to use local disk) ───────────
# When S3_UPLOADS_BUCKET is set, admin photo uploads go to S3 and
# UPLOADS_CDN_URL is then REQUIRED (it's how the public URL is built).
# Note: Render Web Services (and most PaaS) have ephemeral filesystems,
# so the local-disk fallback will lose admin uploads on every redeploy.
# Use S3 in any PaaS environment.
S3_UPLOADS_BUCKET=
AWS_REGION=eu-south-1
UPLOADS_CDN_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Runtime tuning (OPTIONAL) ───────────────────────────────────────
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=3
PORT=3000
